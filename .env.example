# Database (Neon / PostgreSQL)
DATABASE_URL=postgres://user:password@host:5432/dbname

# Session
SESSION_SECRET=change-me-use-openssl-rand-hex-32

# Google OAuth (sign-in only — openid email profile)
# Create these in Google Cloud Console → APIs & Services → Credentials.
# OAuth consent screen must be set to "Internal" (IgniteTech Workspace).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional: hardcode a single callback URL. If unset, the server derives
# https://<req.hostname>/api/auth/google/callback automatically — useful
# when the same deployment serves multiple hostnames (prod + replit preview).
# GOOGLE_REDIRECT_URI=https://sscmadashboard.ignitetech.ai/api/auth/google/callback

# OpenAI (via Replit AI Integrations)
AI_INTEGRATIONS_OPENAI_BASE_URL=
AI_INTEGRATIONS_OPENAI_API_KEY=

# Server
PORT=5000
NODE_ENV=development
